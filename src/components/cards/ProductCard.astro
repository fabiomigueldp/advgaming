---
/**
 * ProductCard Component
 * Image-led product tile for the products listing.
 */
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import { localizeUrl, type SupportedLocale } from "@util/translate";

interface Props {
  product: CollectionEntry<"products">;
  lang: SupportedLocale;
}

const { product, lang } = Astro.props;
const { data, slug } = product as any;
const productData = data as any;

const productSlug = slug.includes("/") ? slug.split("/").pop() : slug;
const productUrl = localizeUrl(`/products/${productSlug}`, lang);
const productLevel = productData.product_level as "free" | "basic" | "custom";
const isPlaceholder = String(data.thumbnail).includes("placeholder-product");
const galleryImages = Array.isArray(data.gallery) && data.gallery.length > 0
  ? data.gallery
  : [data.thumbnail];
const hasGallery = !isPlaceholder && galleryImages.length > 1;
const galleryStepMs = 2600;
const galleryDuration = `${galleryImages.length * galleryStepMs}ms`;

const levelLabels = {
  free: "Starter Pack",
  basic: "Creator Pack",
  custom: "Sob medida",
} as const;

const actionLabels = {
  free: "Baixar kit",
  basic: "Ver detalhes",
  custom: "Solicitar",
} as const;

const priceLabel = productLevel === "free" ? "Grátis" : data.price_display;
---

<article class={`product-card product-card--${productLevel} ${isPlaceholder ? "product-card--placeholder" : ""} ${hasGallery ? "product-card--gallery" : ""}`}>
  <a href={productUrl} class="product-card__link" aria-label={`${data.name}: ${actionLabels[productLevel]}`}>
    <div class="product-card__media" aria-hidden={isPlaceholder ? "true" : "false"}>
      {isPlaceholder ? (
        <div class="product-card__fallback">
          <span class="product-card__fallback-panel product-card__fallback-panel--one"></span>
          <span class="product-card__fallback-panel product-card__fallback-panel--two"></span>
          <span class="product-card__fallback-panel product-card__fallback-panel--three"></span>
        </div>
      ) : (
        galleryImages.map((image, index) => (
          <img
            src={image}
            alt=""
            class="product-card__image"
            loading={index === 0 ? "lazy" : "eager"}
            style={`--gallery-duration: ${galleryDuration}; --gallery-delay: ${index * galleryStepMs}ms;`}
          />
        ))
      )}
    </div>

    <div class="product-card__shade"></div>

    <div class="product-card__content">
      <div class="product-card__meta">
        <span>{levelLabels[productLevel]}</span>
        {hasGallery && <span>{galleryImages.length} cores</span>}
        {productData.delivery_time && <span>{productData.delivery_time}</span>}
      </div>

      <div class="product-card__copy">
        <h3 class="product-card__title">{data.name}</h3>
        <p class="product-card__description">{data.short_description}</p>
      </div>

      <div class="product-card__footer">
        <span class="product-card__price">{priceLabel}</span>
        <span class="product-card__action">
          {actionLabels[productLevel]}
          <Icon name="right" class="product-card__action-icon" />
        </span>
      </div>
    </div>
  </a>
</article>

<style>
  .product-card {
    --product-accent: var(--color-primary);
    --product-accent-strong: var(--color-primary);
    position: relative;
    min-height: 31rem;
    overflow: hidden;
    border: 1px solid rgb(var(--border));
    border-radius: 8px;
    background-color: rgb(var(--card-bg));
    color: rgb(var(--card-fg));
    box-shadow: 0 24px 60px -42px rgb(var(--shadow-color) / 0.75);
    isolation: isolate;
    transition:
      transform 220ms ease,
      border-color 220ms ease,
      box-shadow 220ms ease;
  }

  .product-card--free {
    --product-accent: var(--color-success);
    --product-accent-strong: 14 165 233;
  }

  .product-card--basic {
    --product-accent: var(--color-info);
    --product-accent-strong: var(--color-primary);
  }

  .product-card--custom {
    --product-accent: var(--color-accent);
    --product-accent-strong: var(--color-primary);
  }

  .product-card:hover {
    transform: translateY(-4px);
    border-color: rgb(var(--product-accent) / 0.62);
    box-shadow: 0 30px 70px -42px rgb(var(--shadow-color) / 0.92);
  }

  .product-card__link {
    position: relative;
    display: block;
    min-height: inherit;
    color: inherit;
  }

  .product-card__media,
  .product-card__shade {
    position: absolute;
    inset: 0;
  }

  .product-card__media {
    background:
      radial-gradient(circle at 50% 22%, rgb(var(--product-accent) / 0.18), transparent 36%),
      linear-gradient(145deg, rgb(var(--muted-bg)), rgb(var(--card-bg)));
    z-index: -3;
  }

  .product-card__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 1;
    transform: scale(1.01);
    transition:
      opacity 420ms ease,
      transform 520ms ease,
      filter 520ms ease;
  }

  .product-card--gallery .product-card__image {
    opacity: 0;
  }

  .product-card--gallery .product-card__image:first-child {
    opacity: 1;
  }

  .product-card--gallery:hover .product-card__image,
  .product-card--gallery:focus-within .product-card__image {
    animation: product-gallery-fade var(--gallery-duration) linear infinite;
    animation-delay: var(--gallery-delay);
  }

  .product-card:hover .product-card__image {
    transform: scale(1.055);
    filter: saturate(1.08) contrast(1.03);
  }

  .product-card__shade {
    background:
      linear-gradient(180deg, rgb(var(--color-dark) / 0) 28%, rgb(var(--color-dark) / 0.78) 70%, rgb(var(--color-dark) / 0.94) 100%),
      radial-gradient(circle at 50% 18%, rgb(var(--product-accent-strong) / 0.18), transparent 48%);
    z-index: -2;
  }

  .product-card__content {
    position: absolute;
    inset: auto 0 0;
    display: grid;
    gap: 1.25rem;
    padding: 1.25rem;
    color: rgb(var(--color-light));
  }

  .product-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.85rem;
    align-items: center;
    color: rgb(var(--color-light) / 0.68);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .product-card__meta span + span {
    color: rgb(var(--color-light) / 0.52);
  }

  .product-card__copy {
    display: grid;
    gap: 0.55rem;
  }

  .product-card__title {
    font-size: clamp(1.25rem, 2vw, 1.65rem);
    font-weight: 800;
    line-height: 1.05;
    color: rgb(var(--color-light));
  }

  .product-card__description {
    min-height: 2.8rem;
    color: rgb(var(--color-light) / 0.76);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .product-card__footer {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid rgb(var(--color-light) / 0.14);
  }

  .product-card__price {
    color: rgb(var(--color-light));
    font-size: 1.2rem;
    font-weight: 850;
  }

  .product-card--free .product-card__price {
    color: rgb(var(--color-success));
  }

  .product-card__action {
    display: inline-flex;
    gap: 0.4rem;
    align-items: center;
    color: rgb(var(--color-light));
    font-size: 0.85rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .product-card__action-icon {
    width: 1rem;
    height: 1rem;
    color: rgb(var(--product-accent));
    transition: transform 180ms ease;
  }

  .product-card:hover .product-card__action-icon {
    transform: translateX(3px);
  }

  .product-card__fallback {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background:
      radial-gradient(circle at 70% 24%, rgb(var(--product-accent) / 0.36), transparent 26%),
      linear-gradient(145deg, rgb(var(--color-dark)), rgb(var(--product-accent-strong) / 0.24));
  }

  .product-card__fallback::before {
    content: "";
    position: absolute;
    inset: 10% -18% auto auto;
    width: 72%;
    aspect-ratio: 1;
    border: 1px solid rgb(var(--color-light) / 0.16);
    border-radius: 999px;
    background: radial-gradient(circle, rgb(var(--product-accent) / 0.22), transparent 60%);
  }

  .product-card__fallback-panel {
    position: absolute;
    display: block;
    border: 1px solid rgb(var(--color-light) / 0.18);
    border-radius: 8px;
    background:
      linear-gradient(135deg, rgb(var(--color-light) / 0.12), rgb(var(--color-light) / 0.03)),
      linear-gradient(135deg, rgb(var(--product-accent) / 0.26), transparent);
    box-shadow: 0 20px 60px -26px rgb(0 0 0 / 0.9);
    transform: rotate(-6deg);
  }

  .product-card__fallback-panel--one {
    top: 16%;
    left: 10%;
    width: 62%;
    aspect-ratio: 16 / 9;
  }

  .product-card__fallback-panel--two {
    top: 33%;
    right: 8%;
    width: 54%;
    aspect-ratio: 16 / 9;
    transform: rotate(8deg);
  }

  .product-card__fallback-panel--three {
    top: 55%;
    left: 17%;
    width: 42%;
    aspect-ratio: 4 / 3;
    transform: rotate(2deg);
  }

  :global([data-theme="light"]) .product-card {
    box-shadow: 0 24px 70px -48px rgb(var(--shadow-color) / 0.75);
  }

  @media (max-width: 48rem) {
    .product-card {
      min-height: 28rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-card--gallery:hover .product-card__image,
    .product-card--gallery:focus-within .product-card__image {
      animation: none;
    }
  }

  @keyframes product-gallery-fade {
    0%,
    16% {
      opacity: 1;
    }

    20%,
    100% {
      opacity: 0;
    }
  }
</style>
