---
import Picture from "@components/media/Picture.astro";

const layers = [
  {
    number: "01",
    title: "Produtos digitais",
    text: "Packs prontos, variações visuais e arquivos organizados para o criador colocar a live em ordem sem travar no processo.",
    href: "/pt/products/",
    label: "Ver produtos",
  },
  {
    number: "02",
    title: "Design e direção",
    text: "Identidade, telas, overlays e materiais de lançamento pensados para o canal parecer reconhecível em cada ponto de contato.",
    href: "/pt/services/",
    label: "Ver serviços",
  },
  {
    number: "03",
    title: "Squad e comunidade",
    text: "Creators, campanhas, presença social e prova real de uso para manter a marca circulando dentro da cultura de streaming.",
    href: "/pt/squad/",
    label: "Conhecer Squad",
  },
  {
    number: "04",
    title: "Suporte e operação",
    text: "Instalação, orientação, próximos passos e estrutura para o visual não morrer depois do download.",
    href: "/pt/support/",
    label: "Abrir suporte",
  },
];

const paths = [
  ["Começar", "Starter Pack", "Um primeiro visual pronto para OBS, com variações de cor e licença de uso."],
  ["Evoluir", "Creator Pack", "Mais telas, mais acabamento e uma entrega pensada para canais em crescimento."],
  ["Assinar", "Projeto sob medida", "Direção visual construída em cima da identidade, rotina e comunidade do criador."],
];

const creators = [
  {
    name: "Casal Inacreditável",
    handle: "@casalinacreditavel",
    src: "/src/assets/partners/casal-inacreditavel/casal-inacreditavel-squad-art.webp",
  },
  {
    name: "Bobsdih",
    handle: "@bobsdih",
    src: "/src/assets/partners/bobsdih/bobsdih-squad-art.webp",
  },
  {
    name: "Eros Multiverso",
    handle: "@eros_multiverso",
    src: "/src/assets/partners/eros-multiverso/eros-multiverso-squad-art.webp",
  },
];

const marquee = [
  "Gaming",
  "Design",
  "Creators",
  "Network",
  "Produtos",
  "Squad",
  "Suporte",
  "Streaming",
];
---

<section class="home-experience" id="top">
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero__space" aria-hidden="true">
      <video autoplay muted loop playsinline preload="metadata" poster="/video/black_hole_poster.png">
        <source src="/video/black_hole.mp4" type="video/mp4" />
      </video>
    </div>

    <div class="home-shell home-hero__grid">
      <div class="home-hero__copy">
        <h1 id="home-title">Adventury Gaming dá forma à presença de criadores.</h1>
        <p>
          Produtos digitais, direção visual, Squad e suporte para streamers que querem
          transformar cada live, post e ponto de contato em uma experiência mais forte.
        </p>
        <div class="home-actions">
          <a class="home-btn home-btn--primary" href="/pt/services/">
            Explorar a Adventury
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14m0 0-5-5m5 5-5 5" /></svg>
          </a>
          <a class="home-btn home-btn--ghost" href="/pt/products/kit-demo/">
            Baixar Starter Pack
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4v11m0 0 4-4m-4 4-4-4M5 20h14" /></svg>
          </a>
        </div>
      </div>

      <div class="home-singularity" aria-label="Áreas Adventury em órbita">
        <div class="home-singularity__rings" aria-hidden="true"></div>
        <div class="home-singularity__aura" aria-hidden="true"></div>
        <video class="home-singularity__video" autoplay muted loop playsinline preload="metadata" poster="/video/black_hole_poster.png" aria-hidden="true">
          <source src="/video/black_hole.mp4" type="video/mp4" />
        </video>
        <a class="home-orbit home-orbit--products" href="/pt/products/">Produtos</a>
        <a class="home-orbit home-orbit--design" href="/pt/services/">Design</a>
        <a class="home-orbit home-orbit--squad" href="/pt/squad/">Squad</a>
        <a class="home-orbit home-orbit--support" href="/pt/support/">Suporte</a>
      </div>
    </div>
  </section>

  <div class="home-marquee" aria-hidden="true">
    <div class="home-marquee__track">
      <div class="home-marquee__group">
        {marquee.map((item) => <span>{item}</span>)}
      </div>
      <div class="home-marquee__group">
        {marquee.map((item) => <span>{item}</span>)}
      </div>
    </div>
  </div>

  <section class="home-manifest">
    <div class="home-shell home-manifest__grid">
      <h2>O canal começa antes do play.</h2>
      <p>
        A primeira impressão está no visual da live, nos materiais sociais, na clareza
        do produto, na comunidade ao redor e no cuidado depois da entrega. A Adventury
        Gaming junta essas partes em uma presença só.
      </p>
    </div>
  </section>

  <section class="home-layers" aria-labelledby="home-layers-title">
    <div class="home-shell">
      <div class="home-section-title">
        <h2 id="home-layers-title">O que fica em órbita.</h2>
        <p>
          Cada frente tem uma função própria, mas o efeito é conjunto: fazer o criador
          parecer mais preparado, memorável e consistente.
        </p>
      </div>

      <div class="home-layer-list">
        {layers.map((layer) => (
          <article class="home-layer">
            <span>{layer.number}</span>
            <h3>{layer.title}</h3>
            <p>{layer.text}</p>
            <a href={layer.href}>{layer.label}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="home-starter" aria-labelledby="home-starter-title">
    <div class="home-shell home-starter__grid">
      <div class="home-starter__media">
        <img
          src="/images/products/starter-pack/starter-pack-vermelho.webp"
          alt="Preview do Adventury Starter Pack"
          width="1200"
          height="675"
          loading="lazy"
        />
      </div>
      <div class="home-starter__copy">
        <h2 id="home-starter-title">O primeiro passo já pode parecer finalizado.</h2>
        <p>
          O Starter Pack existe para quem quer sair do improviso agora: telas essenciais,
          cinco variações de cor, licença de uso e estrutura pronta para organizar no OBS.
        </p>
        <div class="home-facts" aria-label="Resumo do Starter Pack">
          <span>5 cores</span>
          <span>3 telas</span>
          <span>OBS-ready</span>
        </div>
        <a class="home-text-link" href="/pt/products/kit-demo/">
          Baixar Starter Pack
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 4v11m0 0 4-4m-4 4-4-4M5 20h14" /></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="home-path" aria-labelledby="home-path-title">
    <div class="home-shell">
      <h2 id="home-path-title">Crescer muda a necessidade visual.</h2>
      <div class="home-path__line">
        {paths.map(([stage, title, text]) => (
          <article>
            <span>{stage}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="home-squad" aria-labelledby="home-squad-title">
    <div class="home-shell home-squad__grid">
      <div class="home-squad__copy">
        <h2 id="home-squad-title">A marca ganha vida quando encontra criadores.</h2>
        <p>
          O Squad mostra a Adventury em uso: creators, campanhas e comunidades levando a
          estética para fora da página de produto e para dentro da cultura da live.
        </p>
        <a class="home-text-link" href="/pt/squad/">
          Ver o Squad
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14m0 0-5-5m5 5-5 5" /></svg>
        </a>
      </div>

      <div class="home-roster" aria-label="Criadores do Squad">
        {creators.map((creator) => (
          <figure>
            <Picture
              src={creator.src}
              alt={creator.name}
              sizes="(max-width: 900px) 86vw, 22vw"
              width={520}
              height={650}
              aspect={4 / 5}
              loading="lazy"
            />
            <figcaption>
              <strong>{creator.name}</strong>
              <span>{creator.handle}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="home-final">
    <div class="home-shell home-final__grid">
      <h2>Entre pelo kit. Evolua para uma presença completa.</h2>
      <div>
        <p>
          Comece com o Starter Pack gratuito ou veja como a Adventury pode construir o
          próximo estágio visual do seu canal.
        </p>
        <div class="home-actions">
          <a class="home-btn home-btn--primary" href="/pt/products/kit-demo/">Baixar Starter Pack</a>
          <a class="home-btn home-btn--ghost" href="/pt/services/">Ver serviços</a>
        </div>
      </div>
    </div>
  </section>
</section>

<style>
  :global(.home-canonical-dark) {
    --bg: 3 5 9;
    --fg: 245 247 250;
    --muted-bg: 10 13 19;
    --muted-fg: 158 170 188;
    --card-bg: 10 13 19;
    --card-fg: 245 247 250;
    --card-border: 33 42 57;
    --border: 33 42 57;
    --nav-hover: 255 255 255;
    background: #030509;
  }

  :global(.home-canonical-dark .nav) {
    --nav-fg: 255 255 255;
    --nav-bg: 3 5 9;
  }

  :global(.home-canonical-dark .nav-link.active) {
    color: #6bb4ff;
  }

  :global(.home-canonical-dark .nav button[aria-label="Toggle color scheme"]),
  :global(.home-canonical-dark .floating-cta) {
    display: none;
  }

  :global(.home-canonical-dark .surface-footer) {
    background: #080a10;
    border-top: 1px solid rgba(88, 108, 141, 0.24);
  }

  .home-experience {
    --home-bg: #030509;
    --home-muted: #aab6c9;
    --home-soft: #d9e6ff;
    --home-red: #ef2b35;
    --home-blue: #087bff;
    --home-cyan: #20d8ff;
    overflow: hidden;
    background:
      radial-gradient(circle at 12% 5%, rgba(239, 43, 53, 0.18), transparent 30rem),
      radial-gradient(circle at 80% 20%, rgba(8, 123, 255, 0.18), transparent 34rem),
      linear-gradient(180deg, #030509 0%, #07090f 48%, #030509 100%);
    color: #fff;
  }

  .home-experience,
  .home-experience * {
    box-sizing: border-box;
  }

  .home-shell {
    width: min(100% - 2rem, 75rem);
    margin-inline: auto;
  }

  .home-hero {
    position: relative;
    min-height: clamp(720px, 100svh, 980px);
    display: grid;
    align-items: center;
    overflow: hidden;
    padding: clamp(5.6rem, 8vw, 7rem) 0 clamp(4.2rem, 6vw, 5.6rem);
  }

  .home-hero__space {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    opacity: 0.32;
    pointer-events: none;
  }

  .home-hero__space video {
    width: min(130vw, 110rem);
    height: min(130vw, 110rem);
    object-fit: cover;
    filter: saturate(1.25) contrast(1.22) brightness(1.2);
  }

  .home-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(3, 5, 9, 0.98), rgba(3, 5, 9, 0.72) 48%, rgba(3, 5, 9, 0.9)),
      linear-gradient(180deg, rgba(3, 5, 9, 0.35), #030509 96%);
  }

  .home-hero__grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 0.96fr) minmax(25rem, 0.78fr);
    gap: clamp(2.5rem, 7vw, 6rem);
    align-items: center;
  }

  .home-hero__copy {
    min-width: 0;
    max-width: 50rem;
  }

  .home-hero h1,
  .home-manifest h2,
  .home-section-title h2,
  .home-starter h2,
  .home-path h2,
  .home-squad h2,
  .home-final h2 {
    margin: 0;
    color: #fff;
    font-weight: 950;
    line-height: 0.92;
    letter-spacing: 0;
  }

  .home-hero h1 {
    max-width: 12ch;
    font-size: clamp(3.2rem, 5.85vw, 6rem);
  }

  .home-hero p,
  .home-manifest p,
  .home-section-title p,
  .home-layer p,
  .home-starter p,
  .home-path p,
  .home-squad p,
  .home-final p {
    margin: 0;
    color: var(--home-muted);
    font-size: clamp(1rem, 1.45vw, 1.12rem);
    line-height: 1.68;
  }

  .home-hero__copy p {
    max-width: 39rem;
    margin-top: 1.35rem;
    color: #c5d7f7;
  }

  .home-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.8rem;
  }

  .home-btn {
    box-sizing: border-box;
    display: inline-flex;
    min-height: 3.35rem;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    padding: 0 1.35rem;
    color: #fff;
    font-size: 0.92rem;
    font-weight: 900;
    text-decoration: none;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .home-btn:hover,
  .home-text-link:hover,
  .home-layer a:hover {
    transform: translateY(-2px);
  }

  .home-btn svg,
  .home-text-link svg {
    width: 1.08rem;
    height: 1.08rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.25;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .home-btn--primary {
    border-color: var(--home-red);
    background: var(--home-red);
    box-shadow: 0 24px 70px -34px rgba(239, 43, 53, 0.95);
  }

  .home-btn--ghost {
    background: rgba(4, 7, 13, 0.68);
  }

  .home-singularity {
    position: relative;
    min-height: clamp(27rem, 41vw, 34rem);
    isolation: isolate;
  }

  .home-singularity__rings {
    position: absolute;
    inset: 7%;
    border: 1px solid rgba(32, 216, 255, 0.04);
    border-radius: 50%;
    animation: spin-rings-clockwise 140s linear infinite;
  }

  .home-singularity__rings::before,
  .home-singularity__rings::after {
    content: "";
    position: absolute;
    inset: 12%;
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 50%;
    animation: spin-rings-counter 100s linear infinite;
  }

  .home-singularity__rings::after {
    inset: 28%;
    border: 1px solid rgba(239, 43, 53, 0.04);
    animation: spin-rings-clockwise 70s linear infinite;
  }

  /* Accretion disk neon aura - deep atmospheric background gas */
  .home-singularity__aura {
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(92%, 30.5rem);
    aspect-ratio: 1;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    background: conic-gradient(
      from 0deg,
      transparent 20%,
      rgba(8, 123, 255, 0.16) 45%,
      rgba(239, 43, 53, 0.14) 65%,
      transparent 90%
    );
    filter: blur(40px);
    opacity: 0.7;
    animation: spin-aura 32s linear infinite;
    pointer-events: none;
    z-index: 1;
  }

  .home-singularity__video {
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(88%, 29rem);
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    filter: saturate(1.35) contrast(1.22) brightness(1.22);
    box-shadow:
      0 0 90px rgba(8, 123, 255, 0.22),
      0 0 160px rgba(239, 43, 53, 0.15);
    border: 1.5px solid rgba(255, 255, 255, 0.12);
    animation: gravity-pulse 14s ease-in-out infinite;
    z-index: 2;
  }

  .home-orbit {
    position: absolute;
    z-index: 3;
    color: #e8f3ff;
    font-size: 0.76rem;
    font-weight: 950;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-shadow: 0 0 24px rgba(32, 216, 255, 0.46);
    white-space: nowrap;
    text-decoration: none;
    transition: transform 280ms cubic-bezier(0.16, 1, 0.3, 1), color 280ms ease, text-shadow 280ms ease;
  }

  .home-orbit:hover {
    color: var(--home-cyan);
    text-shadow: 0 0 30px rgba(32, 216, 255, 0.9), 0 0 10px rgba(32, 216, 255, 0.5);
    animation-play-state: paused !important;
  }

  .home-orbit--products {
    left: 0;
    top: 18%;
    animation: float-products 11s ease-in-out infinite;
  }
  .home-orbit--products:hover {
    transform: scale(1.1) translateX(-4px);
  }

  .home-orbit--design {
    right: 2%;
    top: 30%;
    animation: float-design 13s ease-in-out infinite;
  }
  .home-orbit--design:hover {
    transform: scale(1.1) translateX(4px);
  }

  .home-orbit--squad {
    left: 6%;
    bottom: 22%;
    animation: float-squad 12s ease-in-out infinite;
  }
  .home-orbit--squad:hover {
    transform: scale(1.1) translateX(-4px);
  }

  .home-orbit--support {
    right: 7%;
    bottom: 14%;
    animation: float-support 14s ease-in-out infinite;
  }
  .home-orbit--support:hover {
    transform: scale(1.1) translateX(4px);
  }

  /* Subtly animated low-gravity drifting keyframes */
  @keyframes float-products {
    0%, 100% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(-4px) translateX(1.5px); }
  }
  @keyframes float-design {
    0%, 100% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(4px) translateX(-2px); }
  }
  @keyframes float-squad {
    0%, 100% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(-3px) translateX(-2px); }
  }
  @keyframes float-support {
    0%, 100% { transform: translateY(0px) translateX(0px); }
    50% { transform: translateY(3px) translateX(2px); }
  }

  /* Gravitational waves slow breathing keyframes */
  @keyframes gravity-pulse {
    0%, 100% {
      transform: translate(-50%, -50%) scale(1);
      box-shadow:
        0 0 90px rgba(8, 123, 255, 0.22),
        0 0 160px rgba(239, 43, 53, 0.15);
    }
    50% {
      transform: translate(-50%, -50%) scale(1.01);
      box-shadow:
        0 0 115px rgba(8, 123, 255, 0.32),
        0 0 200px rgba(239, 43, 53, 0.22);
    }
  }

  /* Global utility spin keyframes */
  @keyframes spin-aura {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }
  @keyframes spin-rings-clockwise {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes spin-rings-counter {
    from { transform: rotate(360deg); }
    to { transform: rotate(0deg); }
  }

  .home-marquee {
    overflow: hidden;
    border-block: 1px solid rgba(113, 139, 178, 0.18);
    background: #070a10;
  }

  .home-marquee__track {
    display: flex;
    width: max-content;
    animation: home-marquee 30s linear infinite;
  }

  .home-marquee__group {
    display: flex;
    align-items: center;
  }

  .home-marquee span {
    display: inline-flex;
    min-height: 5rem;
    align-items: center;
    padding-inline: clamp(1.5rem, 4vw, 3rem);
    color: #fff;
    font-size: clamp(1.8rem, 4vw, 4.2rem);
    font-weight: 950;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .home-marquee span:nth-child(even) {
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.46);
  }

  .home-manifest,
  .home-layers,
  .home-starter,
  .home-path,
  .home-squad,
  .home-final {
    border-top: 1px solid rgba(113, 139, 178, 0.16);
    padding: clamp(4.5rem, 8vw, 7.5rem) 0;
  }

  .home-manifest__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.75fr) minmax(0, 1.25fr);
    gap: clamp(2rem, 7vw, 6rem);
    align-items: start;
  }

  .home-manifest h2 {
    max-width: 10ch;
    font-size: clamp(3rem, 6vw, 6rem);
  }

  .home-manifest p {
    color: #e8eef8;
    font-size: clamp(1.35rem, 2.55vw, 2.2rem);
    font-weight: 750;
    line-height: 1.18;
  }

  .home-section-title {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(18rem, 0.72fr);
    gap: clamp(2rem, 7vw, 6rem);
    align-items: end;
  }

  .home-section-title h2,
  .home-starter h2,
  .home-path h2,
  .home-squad h2,
  .home-final h2 {
    max-width: 11ch;
    font-size: clamp(2.7rem, 5.7vw, 5.6rem);
  }

  .home-layer-list {
    margin-top: clamp(2.5rem, 5vw, 4.5rem);
    border-top: 1px solid rgba(113, 139, 178, 0.28);
  }

  .home-layer {
    display: grid;
    grid-template-columns: 4rem minmax(12rem, 0.78fr) minmax(0, 1.2fr) auto;
    gap: clamp(1rem, 4vw, 3rem);
    align-items: start;
    border-bottom: 1px solid rgba(113, 139, 178, 0.2);
    padding: clamp(1.45rem, 3.2vw, 2.3rem) 0;
  }

  .home-layer > span {
    color: var(--home-red);
    font-size: 0.8rem;
    font-weight: 950;
  }

  .home-layer h3 {
    margin: -0.18rem 0 0;
    color: #fff;
    font-size: clamp(1.55rem, 3vw, 2.65rem);
    line-height: 0.98;
  }

  .home-layer a,
  .home-text-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
    font-size: 0.86rem;
    font-weight: 950;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 180ms ease, color 180ms ease;
  }

  .home-layer a:hover,
  .home-text-link:hover {
    color: #78bbff;
  }

