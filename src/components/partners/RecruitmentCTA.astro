---
import { Icon } from "astro-icon/components";

const {
  title = "Tem o que e preciso?",
  intro = "Entre para o Squad e receba kits gratuitos, comissao por vendas e visibilidade real.",
  cta_label = "Aplique agora",
  cta_href = "#contact",
} = Astro.props;

const benefits = [
  {
    title: "Receba os kits primeiro",
    description: "Acesso antecipado aos packs gratuitos e lancamentos da Adventury.",
    icon: "offer",
  },
  {
    title: "Cresca com afiliacao",
    description: "Tracking, comissao por venda e oportunidades para criadores ativos.",
    icon: "rocket-launch-bold",
  },
  {
    title: "Entre no radar",
    description: "Destaque no Squad, campanhas oficiais e conexao com a comunidade.",
    icon: "share",
  },
];
---

<section class="recruitment" id="recruitment">
  <div class="container-xl">
    <div class="recruitment__grid">
      <div class="recruitment__copy">
        <h2 class="recruitment__title">{title}</h2>
        <p class="recruitment__intro">{intro}</p>
        <a class="recruitment__cta" href={cta_href}>
          {cta_label}
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="recruitment__cards">
        {benefits.map((benefit) => (
          <div class="recruitment__card">
            <div class="recruitment__icon" aria-hidden="true">
              <Icon name={benefit.icon} class="recruitment__icon-svg" />
            </div>
            <div>
              <h3>{benefit.title}</h3>
              <p>{benefit.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
